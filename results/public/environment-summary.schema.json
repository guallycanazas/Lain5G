{
  "$defs": {
    "utcTimestamp": {
      "format": "date-time",
      "pattern": "^\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])T(?:[01]\\d|2[0-3]):[0-5]\\d:[0-5]\\d(?:\\.\\d{1,6})?Z$",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Non-sensitive verification-host tool versions. This artifact is not a scenario result.",
  "properties": {
    "artifact_type": {
      "const": "public-environment-summary"
    },
    "captured_at_utc": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "limitations": {
      "items": {
        "maxLength": 500,
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "release_version": {
      "pattern": "^[0-9A-Za-z][0-9A-Za-z.+-]{0,63}$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0"
    },
    "scope": {
      "maxLength": 240,
      "minLength": 1,
      "type": "string"
    },
    "source_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "tools": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$",
            "type": "string"
          },
          "version": {
            "maxLength": 80,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "name",
          "version"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "artifact_type",
    "schema_version",
    "captured_at_utc",
    "source_commit",
    "release_version",
    "scope",
    "tools",
    "limitations"
  ],
  "title": "Lain5G Lab Public Environment Summary",
  "type": "object"
}
